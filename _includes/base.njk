{# src/_includes/base.njk #}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{% if title %}{{ title }} · {% endif %}{{ site.title or "Automation KB" }}</title>

    <link rel="stylesheet" href="/assets/site.css?v={{ build.batch }}" />

    {% if site.favicon %}
      <link rel="icon" href="{{ site.favicon }}" />
    {% endif %}
    <link rel="manifest" href="/site.webmanifest" />

    {% if description %}
      <meta name="description" content="{{ description }}" />
    {% elif site.description %}
      <meta name="description" content="{{ site.description }}" />
    {% endif %}

    {% set __siteUrl = site.url or "" %}
    {% set __path = page.url or "/" %}
    {% set __canonical = __siteUrl ~ __path %}
    <link rel="canonical" href="{{ __canonical }}" />

    {% if pagination and pagination.href %}
      {% if pagination.href.previous %}
        <link rel="prev" href="{{ pagination.href.previous }}" />
      {% endif %}
      {% if pagination.href.next %}
        <link rel="next" href="{{ pagination.href.next }}" />
      {% endif %}
    {% endif %}

    {% set __pageTitle = (title and title ~ " · " ~ (site.title or "Automation KB")) or (site.title or "Automation KB") %}
    <meta property="og:title" content="{{ __pageTitle }}" />
    <meta property="og:description" content="{{ description or site.description or "" }}" />
    <meta property="og:url" content="{{ __canonical }}" />
    <meta property="og:site_name" content="{{ site.title or "Automation KB" }}" />
    {% set __isPost = (__path | startsWith("/posts/")) %}
    <meta property="og:type" content="{% if __isPost %}article{% else %}website{% endif %}" />
    {% if __isPost and date %}
      <meta property="article:published_time" content="{{ date | dateIso }}" />
    {% endif %}

    {% set __img = (ogImage or seo.defaultImage or "") %}
    {% set __imgAbs = __img %}
    {% if __img and not (__img | startsWith("http")) %}
      {% set __imgAbs = __siteUrl ~ __img %}
    {% endif %}
    {% if __imgAbs %}
      <meta property="og:image" content="{{ __imgAbs }}" />
    {% endif %}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ __pageTitle }}" />
    <meta name="twitter:description" content="{{ description or site.description or "" }}" />
    {% if __imgAbs %}
      <meta name="twitter:image" content="{{ __imgAbs }}" />
    {% endif %}

    {% set __robots = seo.robots or "" %}
    {% if robots %}{% set __robots = robots %}{% endif %}
    {% if noindex %}{% set __robots = "noindex,follow" %}{% endif %}
    {% if __robots %}
      <meta name="robots" content="{{ __robots }}" />
    {% endif %}
  </head>
  <body>
    {% include "partials/nav.njk" %}

    <main id="content" class="container">
      {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
      <div class="container">
        <small>{{ site.footer or "" }}</small>
      </div>
    </footer>

    <script defer src="/assets/shortcuts.js?v={{ build.batch }}"></script>
    <script defer src="/assets/codecopy.js?v={{ build.batch }}"></script>
    <script defer src="/assets/anchors.js?v={{ build.batch }}"></script>
    <script defer src="/assets/search.js?v={{ build.batch }}"></script>
  </body>
</html>
