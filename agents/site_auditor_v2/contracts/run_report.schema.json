{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/site_auditor_v2/run_report.schema.json",
  "title": "Site Auditor v2 Run Report",
  "type": "object",
  "required": [
    "mode",
    "base_url",
    "ownership_mode",
    "status",
    "run_id",
    "output_folder",
    "timestamp_utc",
    "capability_status",
    "learning_backlog",
    "linked_artifacts",
    "report_mode",
    "executive_answer",
    "findings_count",
    "limitation_count",
    "audit_confidence",
    "findings",
    "operator_feed",
    "operator_memory_core",
    "operator_memory_bridge",
    "priority_summary",
    "page_verdicts",
    "business_impact",
    "next_action_contract",
    "operator_handoff",
    "summary",
    "next_step"
  ],
  "properties": {
    "mode": { "type": "string" },
    "base_url": { "type": "string" },
    "ownership_mode": { "type": "string", "enum": ["OWNED", "EXTERNAL"] },
    "status": { "type": "string", "enum": ["PASS", "PARTIAL", "FAIL"] },
    "run_id": { "type": "string" },
    "output_folder": { "type": "string" },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "capability_status": {
      "type": "object",
      "required": ["capture", "routes", "page_quality", "decision", "link"],
      "properties": {
        "capture": { "type": "string" },
        "routes": { "type": "string" },
        "page_quality": { "type": "string" },
        "decision": { "type": "string" },
        "link": { "type": "string" }
      }
    },
    "learning_backlog": {
      "type": "array",
      "items": { "type": "string" }
    },
    "linked_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "selected_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["route", "type", "priority", "selection_reason"],
        "properties": {
          "route": { "type": "string" },
          "type": { "type": "string" },
          "priority": { "type": "integer" },
          "selection_reason": { "type": "string" }
        }
      }
    },
    "run_budget": {
      "type": "object",
      "required": ["max_routes", "selected_routes", "selection_strategy", "overflow_routes"],
      "properties": {
        "max_routes": { "type": "integer" },
        "selected_routes": { "type": "integer" },
        "selection_strategy": { "type": "string" },
        "overflow_routes": { "type": "integer" },
        "overflow_route_details": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["route", "type", "priority", "selection_reason", "exclusion_reason"],
            "properties": {
              "route": { "type": "string" },
              "type": { "type": "string" },
              "priority": { "type": "integer" },
              "selection_reason": { "type": "string" },
              "exclusion_reason": { "type": "string" }
            }
          }
        }
      }
    },
    "report_mode": { "type": "string", "enum": ["CLEAN", "PROBLEM"] },
    "executive_answer": {
      "type": "object",
      "required": ["overall_verdict", "primary_problem", "audit_scope", "strongest_next_move"],
      "properties": {
        "overall_verdict": { "type": "string" },
        "primary_problem": { "type": "string" },
        "audit_scope": { "type": "string" },
        "strongest_next_move": { "type": "string" }
      }
    },
    "findings_count": { "type": "integer", "minimum": 0 },
    "limitation_count": { "type": "integer", "minimum": 0 },
    "audit_confidence": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_id", "route", "type", "issue_type", "category", "severity", "evidence_refs", "why_it_matters", "recommended_action"],
        "properties": {
          "finding_id": { "type": "string" },
          "route": { "type": "string" },
          "type": { "type": "string", "enum": ["BROKEN_ROUTE", "THIN_ROUTE", "CAPTURE_FAILURE", "ROUTE_OVERFLOW_ONLY"] },
          "issue_type": { "type": "string", "enum": ["BROKEN_ROUTE", "THIN_ROUTE", "CAPTURE_FAILURE", "ROUTE_OVERFLOW_ONLY"] },
          "category": { "type": "string", "enum": ["DEFECT", "LIMITATION"] },
          "severity": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "why_it_matters": { "type": "string" },
          "recommended_action": { "type": "string" }
        }
      }
    },
    "operator_feed": {
      "type": "object",
      "required": [
        "system_state",
        "primary_constraint",
        "truth_confidence",
        "what_is_reliable",
        "what_is_not_reliable",
        "next_system_move",
        "why_this_move",
        "do_not_do_yet"
      ],
      "properties": {
        "system_state": { "type": "string" },
        "primary_constraint": { "type": "string" },
        "truth_confidence": { "type": "string", "enum": ["high", "medium", "low", ""] },
        "what_is_reliable": { "type": "array", "items": { "type": "string" } },
        "what_is_not_reliable": { "type": "array", "items": { "type": "string" } },
        "next_system_move": { "type": "string" },
        "why_this_move": { "type": "string" },
        "do_not_do_yet": { "type": "array", "items": { "type": "string" } }
      }
    },
    "operator_memory_core": {
      "type": "object",
      "required": [
        "who_am_i",
        "what_system_is_being_built",
        "primary_asset",
        "end_goal",
        "current_stage",
        "current_focus",
        "what_is_stable",
        "what_is_unstable",
        "agent_learned",
        "agent_cannot_yet",
        "agent_misleading_risk",
        "next_capability_to_build"
      ],
      "properties": {
        "who_am_i": { "type": "string" },
        "what_system_is_being_built": { "type": "string" },
        "primary_asset": { "type": "string" },
        "end_goal": { "type": "string" },
        "current_stage": { "type": "string" },
        "current_focus": { "type": "string" },
        "what_is_stable": { "type": "array", "items": { "type": "string" } },
        "what_is_unstable": { "type": "array", "items": { "type": "string" } },
        "agent_learned": { "type": "array", "items": { "type": "string" } },
        "agent_cannot_yet": { "type": "array", "items": { "type": "string" } },
        "agent_misleading_risk": { "type": "array", "items": { "type": "string" } },
        "next_capability_to_build": { "type": "string" }
      }
    },
    "operator_memory_bridge": {
      "type": "object",
      "required": [
        "identity_anchor",
        "state_anchor",
        "learning_anchor",
        "must_read_contract",
        "next_operator_posture"
      ],
      "properties": {
        "identity_anchor": {
          "type": "object",
          "required": ["who_am_i", "what_system_is_being_built", "primary_asset", "end_goal"],
          "properties": {
            "who_am_i": { "type": "string" },
            "what_system_is_being_built": { "type": "string" },
            "primary_asset": { "type": "string" },
            "end_goal": { "type": "string" }
          }
        },
        "state_anchor": {
          "type": "object",
          "required": ["current_stage", "current_focus", "what_is_stable", "what_is_unstable"],
          "properties": {
            "current_stage": { "type": "string" },
            "current_focus": { "type": "string" },
            "what_is_stable": { "type": "array", "items": { "type": "string" } },
            "what_is_unstable": { "type": "array", "items": { "type": "string" } }
          }
        },
        "learning_anchor": {
          "type": "object",
          "required": ["agent_learned", "agent_cannot_yet", "agent_misleading_risk", "next_capability_to_build"],
          "properties": {
            "agent_learned": { "type": "array", "items": { "type": "string" } },
            "agent_cannot_yet": { "type": "array", "items": { "type": "string" } },
            "agent_misleading_risk": { "type": "array", "items": { "type": "string" } },
            "next_capability_to_build": { "type": "string" }
          }
        },
        "must_read_contract": {
          "type": "object",
          "required": ["must_read_files", "read_order", "first_file_to_open", "why_read", "minimum_context_after_read"],
          "properties": {
            "must_read_files": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "read_order": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "first_file_to_open": { "type": "string" },
            "why_read": { "type": "string" },
            "minimum_context_after_read": { "type": "string" }
          }
        },
        "next_operator_posture": {
          "type": "object",
          "required": ["next_system_move", "must_do_before_next_task", "what_to_inspect_next", "do_not_do_yet"],
          "properties": {
            "next_system_move": { "type": "string" },
            "must_do_before_next_task": { "type": "array", "items": { "type": "string" } },
            "what_to_inspect_next": { "type": "array", "items": { "type": "string" } },
            "do_not_do_yet": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "priority_summary": {
      "type": "object",
      "required": ["p0_count", "p1_count", "p2_count", "top_issues"],
      "properties": {
        "p0_count": { "type": "integer" },
        "p1_count": { "type": "integer" },
        "p2_count": { "type": "integer" },
        "top_issues": { "type": "array", "maxItems": 3, "items": { "type": "string" } }
      }
    },
    "page_verdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["route", "route_type", "visual_status", "verdict", "issue_count"],
        "properties": {
          "route": { "type": "string" },
          "route_type": { "type": "string" },
          "visual_status": { "type": "string" },
          "verdict": { "type": "string" },
          "issue_count": { "type": "integer" }
        }
      }
    },
    "business_impact": {
      "type": "object",
      "required": ["trust", "navigation", "coverage", "monetization_readiness"],
      "properties": {
        "trust": { "type": "string" },
        "navigation": { "type": "string" },
        "coverage": { "type": "string" },
        "monetization_readiness": { "type": "string" }
      }
    },
    "next_action_contract": {
      "type": "object",
      "required": ["next_task_id", "next_task_objective", "why_this_first", "forbidden_before_done"],
      "properties": {
        "next_task_id": { "type": "string" },
        "next_task_objective": { "type": "string" },
        "why_this_first": { "type": "string" },
        "forbidden_before_done": { "type": "array", "items": { "type": "string" } }
      }
    },
    "operator_handoff": {
      "type": "object",
      "required": [
        "deprecated",
        "mirrors_operator_memory_bridge",
        "ownership_mode",
        "action_scope_explanation",
        "truth_files",
        "read_order",
        "first_file_to_open",
        "exact_reason",
        "must_do_before_next_task",
        "what_to_inspect_next",
        "do_not_do_yet"
      ],
      "properties": {
        "deprecated": { "type": "boolean" },
        "mirrors_operator_memory_bridge": { "type": "boolean" },
        "ownership_mode": { "type": "string", "enum": ["OWNED", "EXTERNAL"] },
        "action_scope_explanation": { "type": "string" },
        "truth_files": { "type": "array", "items": { "type": "string" } },
        "read_order": { "type": "array", "items": { "type": "string" } },
        "first_file_to_open": { "type": "string" },
        "exact_reason": { "type": "string" },
        "must_do_before_next_task": { "type": "array", "items": { "type": "string" } },
        "what_to_inspect_next": { "type": "array", "items": { "type": "string" } },
        "do_not_do_yet": { "type": "array", "items": { "type": "string" } }
      }
    },
    "summary": { "type": "string" },
    "next_step": { "type": "string" }
  }
}
