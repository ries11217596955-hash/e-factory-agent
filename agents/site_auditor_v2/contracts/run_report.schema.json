{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/site_auditor_v2/run_report.schema.json",
  "title": "Site Auditor v2 Run Report",
  "type": "object",
  "required": [
    "mode",
    "base_url",
    "status",
    "run_id",
    "output_folder",
    "timestamp_utc",
    "capability_status",
    "learning_backlog",
    "linked_artifacts",
    "report_mode",
    "executive_answer",
    "findings",
    "priority_summary",
    "page_verdicts",
    "business_impact",
    "next_action_contract",
    "operator_handoff",
    "summary",
    "next_step"
  ],
  "properties": {
    "mode": { "type": "string" },
    "base_url": { "type": "string" },
    "status": { "type": "string", "enum": ["PASS", "PARTIAL", "FAIL"] },
    "run_id": { "type": "string" },
    "output_folder": { "type": "string" },
    "timestamp_utc": { "type": "string", "format": "date-time" },
    "capability_status": {
      "type": "object",
      "required": ["capture", "routes", "page_quality", "decision", "link"],
      "properties": {
        "capture": { "type": "string" },
        "routes": { "type": "string" },
        "page_quality": { "type": "string" },
        "decision": { "type": "string" },
        "link": { "type": "string" }
      }
    },
    "learning_backlog": {
      "type": "array",
      "items": { "type": "string" }
    },
    "linked_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "properties": {
          "name": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "selected_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["route", "type", "priority", "selection_reason"],
        "properties": {
          "route": { "type": "string" },
          "type": { "type": "string" },
          "priority": { "type": "integer" },
          "selection_reason": { "type": "string" }
        }
      }
    },
    "run_budget": {
      "type": "object",
      "required": ["max_routes", "selected_routes", "selection_strategy", "overflow_routes"],
      "properties": {
        "max_routes": { "type": "integer" },
        "selected_routes": { "type": "integer" },
        "selection_strategy": { "type": "string" },
        "overflow_routes": { "type": "integer" },
        "overflow_route_details": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["route", "type", "priority", "selection_reason", "exclusion_reason"],
            "properties": {
              "route": { "type": "string" },
              "type": { "type": "string" },
              "priority": { "type": "integer" },
              "selection_reason": { "type": "string" },
              "exclusion_reason": { "type": "string" }
            }
          }
        }
      }
    },
    "report_mode": { "type": "string", "enum": ["CLEAN", "PROBLEM"] },
    "executive_answer": {
      "type": "object",
      "required": ["overall_verdict", "primary_problem", "audit_scope", "strongest_next_move"],
      "properties": {
        "overall_verdict": { "type": "string" },
        "primary_problem": { "type": "string" },
        "audit_scope": { "type": "string" },
        "strongest_next_move": { "type": "string" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_id", "route", "issue_type", "severity", "evidence_refs", "why_it_matters", "recommended_action"],
        "properties": {
          "finding_id": { "type": "string" },
          "route": { "type": "string" },
          "issue_type": { "type": "string" },
          "severity": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "why_it_matters": { "type": "string" },
          "recommended_action": { "type": "string" }
        }
      }
    },
    "priority_summary": {
      "type": "object",
      "required": ["p0_count", "p1_count", "p2_count", "top_issues"],
      "properties": {
        "p0_count": { "type": "integer" },
        "p1_count": { "type": "integer" },
        "p2_count": { "type": "integer" },
        "top_issues": { "type": "array", "maxItems": 3, "items": { "type": "string" } }
      }
    },
    "page_verdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["route", "route_type", "visual_status", "verdict", "issue_count"],
        "properties": {
          "route": { "type": "string" },
          "route_type": { "type": "string" },
          "visual_status": { "type": "string" },
          "verdict": { "type": "string" },
          "issue_count": { "type": "integer" }
        }
      }
    },
    "business_impact": {
      "type": "object",
      "required": ["trust", "navigation", "coverage", "monetization_readiness"],
      "properties": {
        "trust": { "type": "string" },
        "navigation": { "type": "string" },
        "coverage": { "type": "string" },
        "monetization_readiness": { "type": "string" }
      }
    },
    "next_action_contract": {
      "type": "object",
      "required": ["next_task_id", "next_task_objective", "why_this_first", "forbidden_before_done"],
      "properties": {
        "next_task_id": { "type": "string" },
        "next_task_objective": { "type": "string" },
        "why_this_first": { "type": "string" },
        "forbidden_before_done": { "type": "array", "items": { "type": "string" } }
      }
    },
    "operator_handoff": {
      "type": "object",
      "required": ["truth_files", "read_order", "first_file_to_open", "exact_reason", "do_not_do_yet"],
      "properties": {
        "truth_files": { "type": "array", "items": { "type": "string" } },
        "read_order": { "type": "array", "items": { "type": "string" } },
        "first_file_to_open": { "type": "string" },
        "exact_reason": { "type": "string" },
        "do_not_do_yet": { "type": "array", "items": { "type": "string" } }
      }
    },
    "summary": { "type": "string" },
    "next_step": { "type": "string" }
  }
}
